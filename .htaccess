RewriteEngine On

# Evitar listar directorios
Options -Indexes

# Cuando LiteSpeed devuelva 403 en /servicios, mostrar servicios.html
ErrorDocument 403 /servicios.html

# Prevenir que Apache añada la barra final a los directorios
DirectorySlash Off

# No aplicar reescritura si ya es un archivo físico que existe
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Forzar /servicios a cargar servicios.html aunque exista la carpeta
RewriteCond %{REQUEST_URI} ^/servicios/?$ [NC]
RewriteRule ^servicios/?$ servicios.html [L]

# No aplicar reescritura si ya es un directorio físico que existe (excepto /servicios)
RewriteCond %{REQUEST_URI} !^/servicios/?$
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Intentar cargar el archivo con extensión .html si se solicita sin ella
# Usa DOCUMENT_ROOT para resolver la ruta absoluta (funciona en raíz Y subdirectorios)
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ /$1.html [L]

# Forzar HTTPS (Opcional, recomendado para producción)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

