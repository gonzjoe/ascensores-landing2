RewriteEngine On

# Evitar listar directorios
Options -Indexes

# Prevenir que Apache añada la barra final a los directorios
DirectorySlash Off

# No aplicar reescritura si ya es un archivo físico que existe
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Forzar /servicios (exacto, sin barra final) a cargar servicios.html
RewriteRule ^servicios$ servicios.html [L]

# Forzar /servicios/ (con barra final) a cargar servicios.html
RewriteRule ^servicios/$ servicios.html [L]

# No aplicar reescritura si ya es un directorio (excepto la carpeta servicios)
RewriteCond %{REQUEST_URI} !^/servicios/?$
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Resolver URLs limpias añadiendo .html (funciona en raíz Y en /servicios/)
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Forzar HTTPS (descomentar en producción si se desea)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
